    <!-- Game Guidelines -->
    <string name="game_rules">Game Rules</string>
    <string name="dice_game_basics">Dice Game Basics</string>
    <string name="dice_game_basics_desc">Gundu Ata is a dice game where 6 dice are rolled. You bet on numbers 1-6 that you think will appear.</string>
    <string name="winning_conditions">Winning Conditions</string>
    <string name="winning_conditions_desc">Any number appearing 2 or more times is a winner. Your profit equals bet × frequency (e.g., if a number appears 3 times, profit is 3× your bet).</string>
    <string name="payout_calculation">Payout Calculation</string>
    <string name="payout_calculation_desc">You get your bet back plus profit. Example: Bet ₹500 on a number that appears 3 times → profit ₹1,500, total ₹2,000 (₹500 returned + ₹1,500 profit). No commission.</string>
    <string name="no_winners">No Winners</string>
    <string name="no_winners_desc">If no number appears 2+ times in a round, there are no winners and all bets are lost.</string>
    <string name="betting_strategy">Betting Strategy</string>
    <string name="start_small">Start Small</string>
    <string name="start_small_desc">Begin with smaller bets to understand the game patterns and build your confidence.</string>
    <string name="diversify_bets">Diversify Your Bets</string>
    <string name="diversify_bets_desc">Consider betting on multiple numbers to increase your chances of winning, but manage your bankroll wisely.</string>
    <string name="watch_patterns">Watch the Patterns</string>
    <string name="watch_patterns_desc">Observe previous rounds to identify patterns, though each round is independent and random.</string>
    <string name="set_limits">Set Limits</string>
    <string name="set_limits_desc">Always set a budget and stick to it. Never bet more than you can afford to lose.</string>
    <string name="pro_tips">Pro Tips</string>
    <string name="timing_matters">Timing Matters</string>
    <string name="timing_matters_desc">Place your bets before the round closes. Late bets may not be accepted.</string>
    <string name="check_balance">Check Your Balance</string>
    <string name="check_balance_desc">Always ensure you have sufficient balance before placing bets.</string>
    <string name="review_history">Review History</string>
    <string name="review_history_desc">Check your betting history to track your performance and learn from past rounds.</string>
    <string name="stay_updated">Stay Updated</string>
    <string name="stay_updated_desc">Keep an eye on announcements and system information for any game updates or special events.</string>
    <string name="important_notes">Important Notes</string>
    <string name="important_notes_content">• All dice rolls are random and fair\n• Each round is independent\n• Results are final once dice are rolled\n• Play responsibly and within your means\n• Contact support if you have any questions\n\n• Company reserves the right to suspend/void any id/bets if the same is found to be illegitimate. For example incase of VPN/robot-use/multiple entry from same or different IP and others. Note: only winning bets will be voided.\n• In any circumstances management decision will be final.</string>
    
