<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppCompat theme required for AppCompatDelegate.setApplicationLocales (per-app language) to work -->
    <style name="Theme.GunduAta" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="colorPrimary">@color/primary_yellow</item>
        <item name="colorPrimaryDark">@color/black</item>
    </style>
    <color name="black">#FF121212</color>
    <color name="primary_yellow">#FFDAA520</color>

    <style name="BaseUnityGameActivityTheme" parent="android:Theme.Black.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
