    <!-- Game Guidelines -->
    <string name="game_rules">गेम नियम</string>
    <string name="dice_game_basics">डाइस गेम बेसिक्स</string>
    <string name="dice_game_basics_desc">गुंडू आटा एक डाइस गेम है जहां 6 डाइस रोल किए जाते हैं। आप 1-6 नंबरों पर बेट लगाते हैं जो आपको लगता है कि आएंगे।</string>
    <string name="winning_conditions">जीतने की शर्तें</string>
    <string name="winning_conditions_desc">2 या अधिक बार आने वाला कोई भी नंबर विजेता है। आपका लाभ = बेट × आवृत्ति (जैसे: अगर नंबर 3 बार आता है, लाभ 3× आपकी बेट)।</string>
    <string name="payout_calculation">भुगतान गणना</string>
    <string name="payout_calculation_desc">आपको अपनी बेट वापस मिलती है और लाभ भी। उदाहरण: 3 बार आने वाले नंबर पर ₹500 बेट → लाभ ₹1,500, कुल ₹2,000। कोई कमीशन नहीं।</string>
    <string name="no_winners">कोई विजेता नहीं</string>
    <string name="no_winners_desc">अगर एक राउंड में कोई नंबर 2+ बार नहीं आता, तो कोई विजेता नहीं और सभी बेट खो जाते हैं।</string>
    <string name="betting_strategy">बेटिंग रणनीति</string>
    <string name="start_small">छोटे से शुरू करें</string>
    <string name="start_small_desc">गेम पैटर्न समझने और आत्मविश्वास बनाने के लिए छोटी बेट से शुरू करें।</string>
    <string name="diversify_bets">अपनी बेट विविध करें</string>
    <string name="diversify_bets_desc">जीतने की संभावना बढ़ाने के लिए कई नंबरों पर बेट लगाने पर विचार करें, लेकिन बैंकरोल का सावधानी से प्रबंधन करें।</string>
    <string name="watch_patterns">पैटर्न देखें</string>
    <string name="watch_patterns_desc">पैटर्न पहचानने के लिए पिछले राउंड देखें, हालांकि हर राउंड स्वतंत्र और यादृच्छिक है।</string>
    <string name="set_limits">सीमा निर्धारित करें</string>
    <string name="set_limits_desc">हमेशा बजट निर्धारित करें और उस पर टिके रहें। जितना खो सकते हैं उससे अधिक बेट न लगाएं।</string>
    <string name="pro_tips">प्रो टिप्स</string>
    <string name="timing_matters">समय मायने रखता है</string>
    <string name="timing_matters_desc">राउंड बंद होने से पहले बेट लगाएं। देर से बेट स्वीकार नहीं हो सकते।</string>
    <string name="check_balance">अपना बैलेंस चेक करें</string>
    <string name="check_balance_desc">बेट लगाने से पहले हमेशा पर्याप्त बैलेंस सुनिश्चित करें।</string>
    <string name="review_history">इतिहास समीक्षा करें</string>
    <string name="review_history_desc">अपने प्रदर्शन को ट्रैक करने और पिछले राउंड से सीखने के लिए बेटिंग इतिहास चेक करें।</string>
    <string name="stay_updated">अपडेट रहें</string>
    <string name="stay_updated_desc">किसी भी गेम अपडेट या विशेष इवेंट के लिए घोषणाओं और सिस्टम जानकारी पर नजर रखें।</string>
    <string name="important_notes">महत्वपूर्ण नोट्स</string>
    <string name="important_notes_content">• सभी डाइस रोल यादृच्छिक और निष्पक्ष हैं\n• हर राउंड स्वतंत्र है\n• डाइस रोल होने के बाद परिणाम अंतिम\n• अपनी सीमा में जिम्मेदारी से खेलें\n• प्रश्न हों तो सहायता से संपर्क करें\n\n• अवैध पाए जाने पर कंपनी किसी भी आईडी/बेट को निलंबित/रद्द करने का अधिकार रखती है। जैसे VPN/रोबोट-उपयोग/एक ही या अलग IP से एकाधिक प्रवेश आदि। नोट: केवल जीतने वाली बेट रद्द होंगी।\n• किसी भी परिस्थिति में प्रबंधन का निर्णय अंतिम होगा।</string>
    
